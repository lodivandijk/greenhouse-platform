#!/bin/sh
set -eu

GRADLE_VERSION="9.2.1"
PROJECT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
GRADLE_HOME_DIR="${HOME}/.gradle/greenhouse-wrapper/gradle-${GRADLE_VERSION}"
GRADLE_BIN="${GRADLE_HOME_DIR}/bin/gradle"
ZIP_FILE="${HOME}/.gradle/greenhouse-wrapper/gradle-${GRADLE_VERSION}-bin.zip"

if [ ! -x "${GRADLE_BIN}" ]; then
  mkdir -p "$(dirname "${ZIP_FILE}")"
  if [ ! -f "${ZIP_FILE}" ]; then
    echo "Downloading Gradle ${GRADLE_VERSION}..."
    curl -fL "https://services.gradle.org/distributions/gradle-${GRADLE_VERSION}-bin.zip" -o "${ZIP_FILE}"
  fi
  echo "Installing Gradle ${GRADLE_VERSION}..."
  rm -rf "${GRADLE_HOME_DIR}"
  unzip -q "${ZIP_FILE}" -d "$(dirname "${GRADLE_HOME_DIR}")"
fi

exec "${GRADLE_BIN}" -p "${PROJECT_DIR}" "$@"
